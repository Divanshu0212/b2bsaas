<configuration>
    <!--
      T4.3: JSON structured logging to stdout with org_id/user_id/trace_id correlation.
      - org_id / user_id are put into MDC by TenantFilter (HTTP) and IdempotentConsumer
        (Kafka), both snake_case to match the includeMdcKeyName entries below.
      - trace_id: on the HTTP path there's an active OTel server span but nothing has put
        its id into MDC, so the OTel logback-mdc instrumentation (opentelemetry-logback-
        mdc-1.0, on the classpath via the OTel starter) is wired in to inject trace_id/
        span_id automatically. On the Kafka path IdempotentConsumer also sets trace_id
        explicitly from the inbound event. Either way the emitted field is `trace_id`,
        the key Loki's derived-field trace->Tempo correlation looks for (T4.3).
    -->
    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>org_id</includeMdcKeyName>
            <includeMdcKeyName>user_id</includeMdcKeyName>
            <includeMdcKeyName>trace_id</includeMdcKeyName>
            <includeMdcKeyName>event_id</includeMdcKeyName>
        </encoder>
    </appender>

    <!--
      OTel MDC instrumentation: copies the active span's trace_id/span_id into MDC for
      every log event so HTTP-thread logs correlate to their trace without a hand-rolled
      filter. Delegates to the JSON appender above.
    -->
    <appender name="OTEL_MDC" class="io.opentelemetry.instrumentation.logback.mdc.v1_0.OpenTelemetryAppender">
        <appender-ref ref="JSON"/>
    </appender>

    <root level="INFO">
        <appender-ref ref="OTEL_MDC"/>
    </root>
</configuration>
